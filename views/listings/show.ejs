<% layout("layout/boilerplate")-%>

    <body>
    
        <script>
          const mapToken = '<%= process.env.MAP_TOKEN %>';
          const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
        </script>
        
        <div class="row mt-4 mb-4 justify-content-center">
          <div class="col-12 col-md-10 col-lg-8 col-xl-6">
            <div class="show-layout">
              <div class="card listing-card">
                <h2 class="mb-3"><%= listing.title %></h2>
                <img src="<%= listing.image.url %>" class="card-img-top show-image mb-4" alt="<%= listing.title %>">
                <div class="card-body">
                  <p class="card-text">
                    <b>Owned by <%= listing.owner.username %></b><br>
                    <%= listing.description %><br>
                    <span style="font-size:1.2rem; font-weight:600; color:#fe424d;">&#8377;<%= listing.price.toLocaleString("en-IN") %></span> <br>
                    <i class="fa-solid fa-location-dot" style="color:#fe424d;"></i> <%= listing.location %>, <%= listing.country %>
                  </p>
                </div>
              </div>
        
              <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
                <div class="btns mt-3">
                  <form method="get" action="/listings/<%= listing._id %>/edit">
                    <button class="btn btn-dark edit-btn">Edit</button>
                  </form>
                  <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                    <button class="btn btn-outline-danger">Delete</button>
                  </form>
                </div>
              <% } %>
        
              <hr>
        
              <% if (isAuthenticated) { %>
                <h4 class="mt-3">Leave a Review</h4>
                <form method="post" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation mt-2">
                  <div>
                    <label for="rating" class="form-label">Rating</label>
                    <fieldset class="starability-grow">
                      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                      <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                      <label for="first-rate1" title="Terrible">1 star</label>
                      <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                      <label for="first-rate2" title="Not good">2 stars</label>
                      <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                      <label for="first-rate3" title="Average">3 stars</label>
                      <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                      <label for="first-rate4" title="Very good">4 stars</label>
                      <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                      <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                  </div>
                  <div class="mt-2">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea name="review[comment]" id="comment" class="form-control" rows="4" required></textarea>
                    <div class="invalid-feedback">Comment should be valid</div>
                  </div>
                  <button class="btn btn-dark add-btn mt-3">Submit</button>
                </form>
                <hr>
              <% } %>
        
              <% if(listing.reviews.length > 0){ %>
                <h4 class="mt-3">All Reviews</h4>
                <div class="row g-3 mt-1">
                  <% for (review of listing.reviews) { %>
                    <div class="col-12 col-md-6">
                      <div class="card mb-3">
                        <div class="card-body">
                          <h5 class="card-title">@<%= review.author.username %></h5>
                          <p class="starability-result" data-rating="<%= review.rating %>"></p>
                          <p class="card-text"><%= review.comment %></p>
                          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% } %>
                </div>
                <hr>
              <% } %>
        
              <div class="mt-3">
                <h3>Where You'll Be</h3>
                <div id="map" class="mt-2"></div>
              </div>
            </div>
          </div>
        </div>
        
        <script src="/js/map.js"></script>
        
    </body>