<% layout("layout/boilerplate")-%>
<body>
<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">
    <div class="mt-4 mb-4 p-4" style="background:#fff; border-radius:1rem; box-shadow:0 2px 12px rgba(0,0,0,0.06);">
      <h3 class="mb-3">Edit Listing</h3>

      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required>
          <div class="invalid-feedback">Title should be valid</div>
          <div class="valid-feedback">Looks Good!</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" class="form-control" rows="3" required><%= listing.description %></textarea>
          <div class="invalid-feedback">Enter short description</div>
        </div>

        <div class="mb-3">
          <label>Current Image</label><br>
          <img src="<%= URL %>" style="max-width:100%; height:auto; border-radius:0.75rem; max-height:200px; object-fit:cover;" class="mt-1">
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Upload New Image</label>
          <input type="file" name="listing[image]" class="form-control" value="<%= listing.image %>">
        </div>

        <div class="row g-3">
          <div class="col-12 col-sm-4">
            <label for="price" class="form-label">Price</label>
            <input type="number" name="listing[price]" value="<%= listing.price %>" required class="form-control">
            <div class="invalid-feedback">Price should be valid</div>
          </div>
          <div class="col-12 col-sm-8">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" value="<%= listing.location %>" required class="form-control">
            <div class="invalid-feedback">Location should be valid</div>
          </div>
        </div>

        <div class="mb-3 mt-3">
          <label for="country" class="form-label">Country</label>
          <input type="text" name="listing[country]" value="<%= listing.country %>" required class="form-control">
          <div class="invalid-feedback">Country should be valid</div>
        </div>

        <button class="btn btn-dark edit-btn mt-2">Submit</button>
      </form>
    </div>
  </div>
</div>
</body>